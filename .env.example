# Copy to .env and fill in real values. Never commit .env.
# A free hosted Postgres works well: Neon, Supabase, or Vercel Postgres.

# Postgres connection string used by Prisma (server-side only).
DATABASE_URL="postgresql://..."

# LLM via a LiteLLM (OpenAI-compatible) gateway — server-side only.
LITELLM_BASE_URL="https://your-litellm-host/v1"
LITELLM_API_KEY=""
LITELLM_MODEL="gpt-4o"

# Vercel Blob — auth resolves from the OIDC token + store id (no read/write token).
# On Vercel these are injected automatically; for local dev run `vercel env pull`.
VERCEL_OIDC_TOKEN=""
BLOB_STORE_ID=""

# Auth secret for signing session tokens (server-side only). Generate with:
#   openssl rand -base64 32
AUTH_SECRET=""

# App environment: development | staging | production (read on client + server).
NEXT_PUBLIC_APP_ENV="development"

# Optional: base URL for an EXTERNAL API consumed via src/lib/api_client.ts.
# Leave empty to call same-origin route handlers.
NEXT_PUBLIC_API_BASE_URL=""
